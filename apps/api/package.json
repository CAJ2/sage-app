{
  "name": "@sageleaf/api",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "author": "",
  "files": [
    "dist",
    "temp"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "codegen": "graphql-codegen --config graphql-codegen.ts",
    "codegen:db": "./db-defs.sh",
    "codegen:schema": "SCHEMA_GEN=1 nest start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "lint": "pnpm exec oxlint --fix",
    "lint:ci": "pnpm exec oxlint --deny-warnings",
    "fmt": "pnpm exec oxfmt",
    "fmt:ci": "pnpm exec oxfmt --check",
    "check:migrations": "pnpm exec mikro-orm migration:check"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@better-auth/api-key": "1.5.6",
    "@mikro-orm/core": "^6.6.6",
    "@mikro-orm/migrations": "^6.6.6",
    "@mikro-orm/nestjs": "^6.1.1",
    "@mikro-orm/postgresql": "^6.6.6",
    "@mikro-orm/reflection": "^6.6.6",
    "@mikro-orm/seeder": "^6.6.6",
    "@mikro-orm/sql-highlighter": "^1.0.1",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/terminus": "^11.1.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "ajv": "^8.17.1",
    "better-auth": "1.5.6",
    "body-parser": "^2.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv-flow": "^4.1.0",
    "dset": "^3.1.4",
    "express": "^5.2.1",
    "graphql": "^16.10.0",
    "graphql-scalars": "^1.24.1",
    "helmet": "^8.1.0",
    "jsonld": "^8.3.3",
    "kysely": "^0.28.14",
    "kysely-knex": "^0.2.0",
    "lodash": "^4.17.21",
    "luxon": "^3.7.2",
    "meilisearch": "^0.56.0",
    "nanoid": "^3.0.0",
    "nestjs-cls": "^6.2.0",
    "nestjs-i18n": "^10.5.1",
    "node-ipinfo": "^4.3.0",
    "posthog-node": "^5.28.6",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.2",
    "sql-formatter": "^15.7.2",
    "windmill-client": "^1.666.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@graphql-codegen/add": "^6.0.0",
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@mikro-orm/cli": "^6.6.6",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.17",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.21",
    "@types/body-parser": "^1.19.6",
    "@types/express": "^5.0.6",
    "@types/jsonld": "^1.5.15",
    "@types/lodash": "^4.17.24",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "graphql-tag": "^2.12.6",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.30.0+sha256.fde3cebbd4ed0d6d140b1983743bf575cdd4b15e4d5e5b257425152dce5b1b6a",
  "nx": {
    "targets": {
      "codegen": {
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.ts"
        ],
        "outputs": [
          "{projectRoot}/test/gql/**/*.ts"
        ]
      },
      "codegen:db": {
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.entity.ts"
        ],
        "outputs": [
          "{projectRoot}/temp/**/*"
        ]
      },
      "codegen:schema": {
        "cache": true,
        "inputs": [
          "{projectRoot}/src/**/*.ts"
        ],
        "outputs": [
          "{projectRoot}/schema/schema.gql"
        ]
      },
      "build": {
        "dependsOn": [
          "codegen",
          "codegen:db"
        ]
      },
      "test": {
        "dependsOn": [
          "codegen*"
        ]
      },
      "test:watch": {
        "continuous": true,
        "dependsOn": [
          "codegen*"
        ]
      }
    }
  }
}
