{
  "$schema": "https://docs.tolgee.io/cli-schema.json",
  "projectId": 29733,
  "format": "JSON_TOLGEE",
  "patterns": ["./app/**/*.{ts,vue}"],
  "push": {
    "filesTemplate": "./i18n/{namespace}/{languageTag}.json",
    "languages": ["en"],
    "namespaces": ["common", "frontend"]
  },
  "pull": {
    "path": "./i18n",
    "namespaces": ["common", "frontend"]
  }
}
